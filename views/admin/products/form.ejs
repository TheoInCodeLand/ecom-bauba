<%- include('../layout-start') %>
<style>
  .upload-label {
    display: block;
    border: 2px dashed var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  .upload-label:hover {
    border-color: var(--gold);
  }
</style>
<div class="admin-topbar">
  <div style="display:flex;align-items:center;gap:1rem;">
    <a href="/admin/products" style="color:var(--silver);font-size:0.85rem;">← Products</a>
    <h1><%= product ? `Edit: ${product.name}` : 'Add New Product' %></h1>
  </div>
  <% if (product) { %>
  <div style="display:flex;gap:0.75rem;">
    <a href="/products/<%= product.slug %>" target="_blank" class="btn btn-ghost btn-sm">Preview ↗</a>
    <form method="POST" action="/admin/products/<%= product.id %>/delete" data-confirm="Delete this product? This cannot be undone.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-sm" style="background:#fce8e8;color:#c0392b;border:1px solid #f5a5a5;">Delete</button>
    </form>
  </div>
  <% } %>
</div>

<!--
  NOTE ON FORM STRUCTURE
  ──────────────────────
  <form> elements cannot legally nest in HTML. This page has several
  independent actions living visually inside the "edit product" card
  (per-variant stock update, per-variant delete, add-variant, per-image
  set-primary/delete) — each needs its own <form>/action.

  Rather than nesting those forms inside the main product form (which a
  browser silently — and *inconsistently*, depending on how many variant
  rows exist — collapses/reassigns at parse time, since nested <form> tags
  aren't allowed), the main product form below is intentionally left empty.
  Every field that belongs to "Save Changes" is linked to it explicitly via
  form="product-form", regardless of where it sits in the document. The
  variant/image forms are now genuinely standalone, non-nested forms.
-->
<form id="product-form" method="POST" action="/admin/products/<%= product ? product.id+'/edit' : 'new' %>" enctype="multipart/form-data">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
</form>

<div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;align-items:start;">

  <!-- ── Left Column ── -->
  <div>

    <!-- Basic Info -->
    <div class="admin-card" style="margin-bottom:1.5rem;">
      <div class="admin-card-header">
        <h2>Basic Information</h2>
      </div>
      <div class="admin-card-body">
        <div class="form-group">
          <label class="form-label">Product Name *</label>
          <input class="form-control" name="name" value="<%= product ? product.name : '' %>" required form="product-form">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="form-group">
            <label class="form-label">Brand</label>
            <input class="form-control" name="brand" value="<%= product ? (product.brand||'') : '' %>" placeholder="e.g. Gucci, Prada" form="product-form">
          </div>
          <div class="form-group">
            <label class="form-label">Category *</label>
            <select class="form-control" name="categoryId" required form="product-form">
              <option value="">Select category</option>
              <% (categories || []).forEach(cat => { %>
              <option value="<%= cat.id %>" <%= product && product.category_id===cat.id?'selected':'' %>>
                <%- '- '.repeat(cat.depth) %><%= cat.name %>
              </option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Short Description <span style="color:var(--silver);font-weight:400;">(shown on listing card)</span></label>
          <textarea class="form-control" name="shortDescription" rows="2" style="min-height:70px;" form="product-form"><%= product ? (product.short_description||'') : '' %></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Full Description</label>
          <textarea class="form-control" name="description" rows="6" form="product-form"><%= product ? (product.description||'') : '' %></textarea>
        </div>
      </div>
    </div>

    <!-- Pricing -->
    <div class="admin-card" style="margin-bottom:1.5rem;">
      <div class="admin-card-header">
        <h2>Pricing</h2>
      </div>
      <div class="admin-card-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="form-group">
            <label class="form-label">Base Price (R) *</label>
            <input class="form-control" type="number" name="basePrice" step="0.01" min="0" value="<%= product ? product.base_price : '' %>" required form="product-form">
          </div>
          <div class="form-group">
            <label class="form-label">Compare At Price (R) <span style="color:var(--silver);font-weight:400;">optional</span></label>
            <input class="form-control" type="number" name="compareAtPrice" step="0.01" min="0" value="<%= product ? (product.compare_at_price||'') : '' %>" placeholder="For sale display" form="product-form">
          </div>
        </div>
      </div>
    </div>

    <!-- Product Details -->
    <div class="admin-card" style="margin-bottom:1.5rem;">
      <div class="admin-card-header">
        <h2>Product Details</h2>
      </div>
      <div class="admin-card-body">
        <div class="form-group">
          <label class="form-label">Material / Composition</label>
          <textarea class="form-control" name="materialDetails" rows="2" style="min-height:60px;" form="product-form"><%= product ? (product.material_details||'') : '' %></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Care Instructions</label>
          <textarea class="form-control" name="careInstructions" rows="2" style="min-height:60px;" form="product-form"><%= product ? (product.care_instructions||'') : '' %></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="form-group">
            <label class="form-label">Fit &amp; Sizing Notes</label>
            <textarea class="form-control" name="fitAndSizing" rows="2" style="min-height:60px;" form="product-form"><%= product ? (product.fit_and_sizing||'') : '' %></textarea>
          </div>
          <div class="form-group">
            <label class="form-label">Country of Origin</label>
            <input class="form-control" name="originCountry" value="<%= product ? (product.origin_country||'') : '' %>" placeholder="e.g. Italy" form="product-form">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Tags <span style="color:var(--silver);font-weight:400;">(comma-separated)</span></label>
          <input class="form-control" name="tags" value="<%= product && product.tags ? product.tags.join(', ') : '' %>" placeholder="handbag, leather, black..." form="product-form">
        </div>
      </div>
    </div>

    <!-- SEO -->
    <div class="admin-card" style="margin-bottom:1.5rem;">
      <div class="admin-card-header">
        <h2>SEO</h2>
      </div>
      <div class="admin-card-body">
        <div class="form-group">
          <label class="form-label">Meta Title <span style="color:var(--silver);font-weight:400;">max 60 chars</span></label>
          <input class="form-control" name="metaTitle" maxlength="60" value="<%= product ? (product.meta_title||'') : '' %>" form="product-form">
        </div>
        <div class="form-group">
          <label class="form-label">Meta Description <span style="color:var(--silver);font-weight:400;">max 160 chars</span></label>
          <textarea class="form-control" name="metaDescription" maxlength="160" rows="2" style="min-height:60px;" form="product-form"><%= product ? (product.meta_description||'') : '' %></textarea>
        </div>
      </div>
    </div>

    <!-- ── VARIANTS ── -->
    <div class="admin-card" style="margin-bottom:1.5rem;">
      <div class="admin-card-header">
        <h2>Product Variants</h2>
        <% if (product) { %>
        <button type="button" class="btn btn-outline btn-sm" id="add-variant-btn" data-action="toggle-add-variant">+ Add Variant</button>
        <% } else { %>
        <span style="font-size:0.78rem;color:var(--silver);">Save product first to add variants</span>
        <% } %>
      </div>
      <div class="admin-card-body" style="padding:0;">

        <!-- Existing Variants Table -->
        <% if (variants && variants.length) { %>
        <div class="table-wrap" style="margin:0;">
          <table style="margin:0;">
            <thead>
              <tr>
                <th>Attributes</th>
                <th>SKU</th>
                <th style="text-align:center;">Stock</th>
                <th>Price Override</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% variants.forEach(v => { %>
              <tr>
                <td>
                  <% if (v.attributes && v.attributes.length) { %>
                  <% v.attributes.forEach(a => { %>
                  <span style="display:inline-block;background:var(--pearl);border:1px solid var(--border);border-radius:4px;font-size:0.75rem;padding:0.15rem 0.5rem;margin:0.1rem;"><strong><%= a.attribute_type %>:</strong> <%= a.attribute_value %></span>
                  <% }) %>
                  <% } else { %>
                  <span style="color:var(--silver);font-size:0.8rem;">Default variant</span>
                  <% } %>
                </td>
                <td style="font-size:0.8rem;color:var(--silver);"><%= v.sku || '—' %></td>
                <td style="text-align:center;">
                  <form method="POST" action="/admin/products/<%= product.id %>/variants/<%= v.id %>/stock" style="display:flex;align-items:center;justify-content:center;gap:0.4rem;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="number" name="quantity" value="<%= v.stock_quantity %>" min="0" class="stock-input" style="width:70px;text-align:center;padding:0.25rem 0.4rem;border:1px solid var(--border);border-radius:4px;font-size:0.85rem;font-weight:600;color:<%= v.stock_quantity<=0?'#c0392b':v.stock_quantity<=v.low_stock_threshold?'#b7791f':'var(--obsidian)' %>;">
                  </form>
                </td>
                <td style="font-size:0.85rem;">
                  <% if (v.price_override) { %>
                  <strong><%= formatCurrency(v.price_override) %></strong>
                  <% } else { %>
                  <span style="color:var(--silver);">Base price</span>
                  <% } %>
                </td>
                <td>
                  <form method="POST" action="/admin/products/<%= product.id %>/variants/<%= v.id %>/delete" data-confirm="Delete this variant?" style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-ghost btn-sm" style="color:#c0392b;">Delete</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div style="padding:1.5rem;text-align:center;color:var(--silver);font-size:0.85rem;">
          <% if (product) { %>
          No variants yet. Add a variant above to define sizes, colours, etc.
          <% } else { %>
          Save the product first, then add variants.
          <% } %>
        </div>
        <% } %>

        <!-- Add Variant Form (hidden by default) -->
        <% if (product) { %>
        <div id="add-variant-form" style="display:none;padding:1.25rem;border-top:1px solid var(--border);background:#fafaf9;">
          <p style="font-size:0.8rem;font-weight:600;color:var(--obsidian);margin-bottom:1rem;text-transform:uppercase;letter-spacing:0.08em;">New Variant</p>
          <form method="POST" action="/admin/products/<%= product.id %>/variants/new">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <!-- Attributes rows -->
            <div id="attr-rows">
              <div class="attr-row" style="display:grid;grid-template-columns:1fr 1fr 28px;gap:0.5rem;margin-bottom:0.5rem;align-items:center;">
                <select name="attrType_0" class="form-control" style="font-size:0.82rem;">
                  <option value="Size">Size</option>
                  <option value="Colour">Colour</option>
                  <option value="Material">Material</option>
                  <option value="Length">Length</option>
                  <option value="Width">Width</option>
                  <option value="Style">Style</option>
                  <option value="Edition">Edition</option>
                </select>
                <input name="attrValue_0" class="form-control" placeholder="e.g. Small, Red…" style="font-size:0.82rem;" required>
                <span></span>
              </div>
            </div>
            <button type="button" data-action="add-attr-row" style="font-size:0.78rem;color:var(--gold);background:none;border:none;cursor:pointer;padding:0;margin-bottom:0.75rem;">+ Add another attribute</button>

            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-bottom:0.75rem;">
              <div class="form-group" style="margin:0;">
                <label class="form-label" style="font-size:0.75rem;">SKU <span style="color:var(--silver);">optional</span></label>
                <input class="form-control" name="sku" placeholder="e.g. PROD-S-RED" style="font-size:0.82rem;">
              </div>
              <div class="form-group" style="margin:0;">
                <label class="form-label" style="font-size:0.75rem;">Stock Qty *</label>
                <input class="form-control" type="number" name="stockQuantity" value="0" min="0" required style="font-size:0.82rem;">
              </div>
              <div class="form-group" style="margin:0;">
                <label class="form-label" style="font-size:0.75rem;">Price Override (R) <span style="color:var(--silver);">optional</span></label>
                <input class="form-control" type="number" name="priceOverride" step="0.01" min="0" placeholder="Leave blank = base price" style="font-size:0.82rem;">
              </div>
            </div>
            <div style="display:flex;gap:0.75rem;">
              <button type="submit" class="btn btn-primary btn-sm">Save Variant</button>
              <button type="button" class="btn btn-ghost btn-sm" data-action="toggle-add-variant">Cancel</button>
            </div>
          </form>
        </div>
        <% } %>

      </div>
    </div>
    <!-- end variants -->

  </div>
  <!-- end left column -->

  <!-- ── Right Column ── -->
  <div>

    <!-- Status & Flags -->
    <div class="admin-card" style="margin-bottom:1.5rem;">
      <div class="admin-card-header">
        <h2>Status &amp; Flags</h2>
      </div>
      <div class="admin-card-body">
        <% const flags = [
            { name:'isActive',         label:'Active (Published)',   checked: product ? product.is_active       : true  },
            { name:'isFeatured',       label:'Featured',             checked: product ? product.is_featured     : false },
            { name:'isNewArrival',     label:'New Arrival',          checked: product ? product.is_new_arrival  : false },
            { name:'isBestseller',     label:'Bestseller',           checked: product ? product.is_bestseller   : false },
            { name:'isLimitedEdition', label:'Limited Edition',      checked: product ? product.is_limited_edition : false },
          ]; %>
        <% flags.forEach(f => { %>
        <label style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid var(--border);cursor:pointer;">
          <span style="font-size:0.85rem;color:var(--ash);"><%= f.label %></span>
          <input type="checkbox" name="<%= f.name %>" value="on" <%= f.checked?'checked':'' %> style="accent-color:var(--gold);width:16px;height:16px;" form="product-form">
        </label>
        <% }) %>
      </div>
    </div>

    <!-- Images -->
    <div class="admin-card" style="margin-bottom:1.5rem;">
      <div class="admin-card-header">
        <h2>Images</h2>
      </div>
      <div class="admin-card-body">
        <% if (images && images.length) { %>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.5rem;margin-bottom:1rem;">
          <% images.forEach(img => { %>
          <div style="position:relative;">
            <img src="<%= img.url %>" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:var(--radius-sm);<%= img.is_primary?'border:2px solid var(--gold);':'' %>">
            <% if (img.is_primary) { %><span style="position:absolute;top:4px;left:4px;background:var(--gold);color:white;font-size:0.6rem;padding:0.1rem 0.4rem;border-radius:2px;">Primary</span><% } %>
            <div style="position:absolute;top:4px;right:4px;display:flex;gap:2px;">
              <% if (!img.is_primary) { %>
              <form method="POST" action="/admin/products/<%= product.id %>/images/<%= img.id %>/primary">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" title="Set as primary" style="background:rgba(0,0,0,0.6);border:none;color:gold;width:22px;height:22px;border-radius:50%;cursor:pointer;font-size:0.7rem;">★</button>
              </form>
              <% } %>
              <form method="POST" action="/admin/products/<%= product.id %>/images/<%= img.id %>/delete" data-confirm="Delete image?">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" style="background:rgba(0,0,0,0.6);border:none;color:white;width:22px;height:22px;border-radius:50%;cursor:pointer;font-size:0.8rem;">✕</button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
        <label class="upload-label">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 0.5rem;display:block;color:var(--silver);">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="17 8 12 3 7 8" />
            <line x1="12" y1="3" x2="12" y2="15" />
          </svg>
          <span style="font-size:0.8rem;color:var(--silver);">Click to upload images<br><span style="font-size:0.72rem;">JPG, PNG, WEBP • Max 10MB each</span></span>
          <input type="file" name="images" multiple accept="image/*" style="display:none;" id="img-upload" form="product-form">
        </label>
        <div id="img-preview" style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.75rem;"></div>
      </div>
    </div>

    <button type="submit" class="btn btn-gold btn-full" style="font-size:0.85rem;" form="product-form">
      <%= product ? 'Save Changes' : 'Create Product' %>
    </button>
  </div>
  <!-- end right column -->

</div>

<script>
  // ── Image preview ──
  function previewImages(input) {
    const preview = document.getElementById('img-preview');
    preview.innerHTML = '';
    [...input.files].forEach(file => {
      const reader = new FileReader();
      reader.onload = e => {
        const img = document.createElement('img');
        img.src = e.target.result;
        img.style = 'width:64px;height:64px;object-fit:cover;border-radius:4px;border:1px solid var(--border);';
        preview.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  }

  // ── Variant add form toggle ──
  function toggleAddVariant() {
    const form = document.getElementById('add-variant-form');
    const btn = document.getElementById('add-variant-btn');
    if (!form || !btn) return;
    const visible = form.style.display !== 'none';
    form.style.display = visible ? 'none' : 'block';
    btn.textContent = visible ? '+ Add Variant' : '✕ Cancel';
  }

  // ── Attribute rows ──
  let attrCount = 1;
  const attrTypes = ['Size', 'Colour', 'Material', 'Length', 'Width', 'Style', 'Edition'];

  function addAttrRow() {
    const container = document.getElementById('attr-rows');
    if (!container) return;
    const idx = attrCount++;
    const row = document.createElement('div');
    row.className = 'attr-row';
    row.style = 'display:grid;grid-template-columns:1fr 1fr 28px;gap:0.5rem;margin-bottom:0.5rem;align-items:center;';
    row.innerHTML = `
    <select name="attrType_${idx}" class="form-control" style="font-size:0.82rem;">
      ${attrTypes.map(t => `<option value="${t}">${t}</option>`).join('')}
    </select>
    <input name="attrValue_${idx}" class="form-control" placeholder="e.g. Medium, Blue…" style="font-size:0.82rem;">
    <button type="button" class="remove-attr-btn" data-action="remove-attr-row" style="background:none;border:none;cursor:pointer;color:#c0392b;font-size:1.1rem;line-height:1;">×</button>
  `;
    container.appendChild(row);
  }

  // ── Delegated click handler (covers add/cancel variant, add/remove attr row) ──
  document.addEventListener('click', (e) => {
    const actionEl = e.target.closest('[data-action]');
    if (!actionEl) return;

    switch (actionEl.dataset.action) {
      case 'toggle-add-variant':
        toggleAddVariant();
        break;
      case 'add-attr-row':
        addAttrRow();
        break;
      case 'remove-attr-row':
        actionEl.closest('.attr-row')?.remove();
        break;
    }
  });

  // ── Delegated submit handler (replaces inline onsubmit="return confirm(...)") ──
  document.addEventListener('submit', (e) => {
    const form = e.target;
    if (form.dataset.confirm && !confirm(form.dataset.confirm)) {
      e.preventDefault();
    }
  });

  // ── Delegated change handler (stock qty auto-submit + image preview) ──
  document.addEventListener('change', (e) => {
    if (e.target.matches('.stock-input')) {
      e.target.form.submit();
    }
    if (e.target.matches('#img-upload')) {
      previewImages(e.target);
    }
  });
</script>
<%- include('../layout-end') %>