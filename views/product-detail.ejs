<%- include('partials/head') %>
<%- include('partials/nav') %>
<%- include('partials/flash') %>
<main>
  <section style="padding:var(--space-2xl) 0 var(--space-3xl);">
    <div class="container">
      <!-- Breadcrumb -->
      <% if (typeof breadcrumb !== 'undefined' && breadcrumb.length) { %>
      <nav class="breadcrumb">
        <a href="/">Home</a><span class="breadcrumb__sep">›</span>
        <a href="/shop">Shop</a><span class="breadcrumb__sep">›</span>
        <% breadcrumb.forEach((c,i) => { %>
        <% if (i < breadcrumb.length-1) { %>
        <a href="/category/<%= c.slug %>"><%= c.name %></a><span class="breadcrumb__sep">›</span>
        <% } else { %>
        <span><%= c.name %></span>
        <% } %>
        <% }) %>
      </nav>
      <% } %>

      <div class="product-detail-grid">
        <!-- Images -->
        <div class="product-images">
          <div class="product-image-main">
            <img id="main-image" src="<%= primaryImage ? primaryImage.url : '' %>" alt="<%= product.name %>" style="width:100%;height:100%;object-fit:cover;">
            <% if (!primaryImage) { %>
            <div style="display:flex;align-items:center;justify-content:center;height:100%;background:var(--pearl);font-size:4rem;">🏛</div>
            <% } %>
          </div>
          <% if (images && images.length > 1) { %>
          <div class="product-image-thumbs">
            <% images.forEach((img,i) => { %>
            <div class="product-image-thumb <%= i===0?'active':'' %>" data-img-url="<%= img.url %>">
              <img src="<%= img.url %>" alt="<%= img.alt_text || product.name %>">
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>

        <!-- Info -->
        <div class="product-info">
          <% if (product.brand) { %>
          <p class="product-detail__brand letter-wide"><%= product.brand %></p>
          <% } %>
          <h1 class="product-detail__name"><%= product.name %></h1>

          <!-- Rating -->
          <% if (product.review_count > 0) { %>
          <div class="product-card__rating" style="margin-bottom:var(--space-md);">
            <span class="stars"><%= '★'.repeat(Math.round(product.average_rating || 0)) %><%= '☆'.repeat(5 - Math.round(product.average_rating || 0)) %></span>
            <a href="#reviews" style="color:var(--silver);font-size:0.8rem;"><%= product.review_count %> review<%= product.review_count !== 1 ? 's' : '' %></a>
          </div>
          <% } %>

          <!-- Price -->
          <div class="product-detail__price">
            <% const price = parseFloat(product.base_price); %>
            <% const compare = product.compare_at_price ? parseFloat(product.compare_at_price) : null; %>
            <span class="price-current<%= compare && compare > price ? ' sale' : '' %>" id="variant-price">R <%= price.toFixed(2) %></span>
            <% if (compare && compare > price) { %>
            <span class="price-compare">R <%= compare.toFixed(2) %></span>
            <span class="badge badge-sale">Save R <%= (compare - price).toFixed(2) %></span>
            <% } %>
          </div>

          <% if (product.short_description) { %>
          <p style="color:var(--ash);margin:var(--space-lg) 0;line-height:1.8;font-size:0.95rem;"><%= product.short_description %></p>
          <% } %>

          <hr class="divider">

          <!-- Variant selectors -->
          <% if (variants && variants.length) { %>
          <div id="variant-selectors" style="margin-bottom:var(--space-xl);">
            <% 
          // Gather unique attribute types
          const attrTypes = [];
          variants.forEach(v => {
            if (v.attributes) v.attributes.forEach(a => {
              if (a && a.attribute_type && !attrTypes.includes(a.attribute_type)) attrTypes.push(a.attribute_type);
            });
          });
        %>
            <% attrTypes.forEach(type => { %>
            <div class="form-group">
              <label class="form-label"><%= type %>: <span id="selected-<%= type.toLowerCase() %>" style="color:var(--obsidian);font-weight:600;text-transform:none;letter-spacing:0;"></span></label>
              <div class="variant-options" data-type="<%= type %>">
                <% 
              const seen = [];
              variants.forEach(v => {
                if (v.attributes) v.attributes.forEach(a => {
                  if (a && a.attribute_type === type && !seen.includes(a.attribute_value)) {
                    seen.push(a.attribute_value);
            %>
                <button type="button" class="variant-btn" data-type="<%= type %>" data-value="<%= a.attribute_value %>">
                  <%= a.display_value || a.attribute_value %>
                </button>
                <% }}) }) %>
              </div>
            </div>
            <% }) %>
          </div>
          <% } %>

          <!-- Quantity -->
          <div class="form-group">
            <label class="form-label">Quantity</label>
            <div class="qty-control">
              <button type="button" id="qty-minus" class="qty-btn">−</button>
              <input type="number" id="qty-input" value="1" min="1" max="99" style="width:60px;text-align:center;border:none;font-size:1rem;font-weight:600;background:transparent;">
              <button type="button" id="qty-plus" class="qty-btn">+</button>
            </div>
          </div>

          <!-- Add to cart -->
          <div style="display:flex;gap:var(--space-md);flex-wrap:wrap;margin-top:var(--space-xl);">
            <form id="add-to-cart-form" action="/cart/add" method="POST" style="flex:1;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="variantId" id="selected-variant-id" value="<%= variants && variants[0] ? variants[0].id : '' %>">
              <input type="hidden" name="quantity" id="form-qty" value="1">
              <button type="submit" id="atc-btn" class="btn btn-primary btn-full" style="min-width:200px;" <% if (variants && !variants.length) { %>disabled<% } %>>
                <span id="atc-text">Add to Cart</span>
              </button>
            </form>

            <% if (isAuthenticated) { %>
            <button class="wishlist-btn btn btn-outline <%= isWishlisted ? 'btn-outline-gold' : '' %>" data-product-id="<%= product.id %>" aria-label="Add to wishlist">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="<%= isWishlisted ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.5">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
              </svg>
            </button>
            <% } %>
          </div>

          <!-- Badges -->
          <div style="display:flex;gap:var(--space-md);flex-wrap:wrap;margin-top:var(--space-xl);">
            <span class="product-trust-badge">🛡 Authenticated</span>
            <span class="product-trust-badge">↩ 30-day returns</span>
            <span class="product-trust-badge">🔒 Secure checkout</span>
          </div>

          <!-- Accordion details -->
          <div class="accordion" style="margin-top:var(--space-2xl);">
            <% if (product.description) { %>
            <details class="accordion-item">
              <summary class="accordion-header">Product Details</summary>
              <div class="accordion-body"><%- product.description %></div>
            </details>
            <% } %>
            <% if (product.material_details) { %>
            <details class="accordion-item">
              <summary class="accordion-header">Material & Composition</summary>
              <div class="accordion-body"><%= product.material_details %></div>
            </details>
            <% } %>
            <% if (product.care_instructions) { %>
            <details class="accordion-item">
              <summary class="accordion-header">Care Instructions</summary>
              <div class="accordion-body"><%= product.care_instructions %></div>
            </details>
            <% } %>
            <% if (product.fit_and_sizing) { %>
            <details class="accordion-item">
              <summary class="accordion-header">Fit & Sizing</summary>
              <div class="accordion-body"><%= product.fit_and_sizing %></div>
            </details>
            <% } %>
            <details class="accordion-item">
              <summary class="accordion-header">Shipping & Returns</summary>
              <div class="accordion-body">Free shipping on orders over R2,500. Express delivery 2-5 business days. Easy 30-day returns. <a href="/returns-policy" style="color:var(--gold)">Full returns policy →</a></div>
            </details>
          </div>
        </div>
      </div>

      <!-- Reviews section -->
      <% if (reviews && reviews.length) { %>
      <section id="reviews" style="margin-top:var(--space-3xl);padding-top:var(--space-2xl);border-top:1px solid var(--border);">
        <h2 style="font-family:var(--font-serif);font-size:2rem;font-weight:300;margin-bottom:var(--space-2xl);">
          Customer Reviews <span style="font-size:1rem;color:var(--silver);font-weight:400;font-family:var(--font-sans);">(<%= reviews.length %>)</span>
        </h2>
        <% if (ratingDist && ratingDist.length) { %>
        <div style="display:flex;gap:var(--space-xl);margin-bottom:var(--space-2xl);flex-wrap:wrap;">
          <div style="text-align:center;">
            <div style="font-size:4rem;font-family:var(--font-serif);line-height:1;color:var(--obsidian);"><%= parseFloat(product.average_rating).toFixed(1) %></div>
            <div class="stars" style="font-size:1.2rem;margin:0.25rem 0;color:var(--gold)">
              <%= '★'.repeat(Math.round(product.average_rating || 0)) %><%= '☆'.repeat(5 - Math.round(product.average_rating || 0)) %>
            </div>
            <div style="font-size:0.8rem;color:var(--silver);"><%= product.review_count %> reviews</div>
          </div>
        </div>
        <% } %>
        <div class="reviews-grid">
          <% reviews.forEach(r => { %>
          <div class="review-card">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-md);">
              <span class="stars"><%= '★'.repeat(r.rating) %><%= '☆'.repeat(5 - r.rating) %></span>
              <% if (r.is_verified_purchase) { %><span style="font-size:0.65rem;color:#27ae60;letter-spacing:0.08em;text-transform:uppercase;font-weight:600;">✓ Verified</span><% } %>
            </div>
            <% if (r.title) { %><h4 style="font-family:var(--font-serif);margin-bottom:0.5rem;"><%= r.title %></h4><% } %>
            <p style="font-size:0.9rem;color:var(--ash);line-height:1.7;margin-bottom:var(--space-md);"><%= r.body %></p>
            <div style="display:flex;align-items:center;gap:0.75rem;">
              <div style="width:32px;height:32px;border-radius:50%;background:var(--pearl);display:flex;align-items:center;justify-content:center;font-family:var(--font-serif);color:var(--gold)"><%= r.first_name.charAt(0) %></div>
              <div style="font-size:0.8rem;color:var(--obsidian);font-weight:600;"><%= r.first_name %> <%= r.last_name ? r.last_name.charAt(0) + '.' : '' %></div>
            </div>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- Related products -->
      <% if (related && related.length) { %>
      <section style="margin-top:var(--space-3xl);">
        <div class="section-header">
          <p class="section-subtitle">You May Also Like</p>
          <h2 class="section-title">Related Pieces</h2>
          <div class="section-divider"></div>
        </div>
        <div class="product-grid">
          <% related.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
          <% }) %>
        </div>
      </section>
      <% } %>

    </div>
  </section>
</main>

<style>
  .product-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    margin-top: var(--space-lg);
  }

  .product-image-main {
    aspect-ratio: 4/5;
    background: var(--pearl);
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .product-image-thumbs {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    flex-wrap: wrap;
  }

  .product-image-thumb {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  .product-image-thumb.active {
    border-color: var(--gold);
  }

  .product-image-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-detail__brand {
    letter-spacing: 0.18em;
    font-size: 0.7rem;
    color: var(--silver);
    margin-bottom: 0.5rem;
  }

  .product-detail__name {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 300;
    margin-bottom: var(--space-md);
    color: var(--obsidian);
  }

  .product-detail__price {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .product-detail__price .price-current {
    font-size: 1.6rem;
    font-weight: 600;
  }

  .qty-control {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .qty-btn {
    background: var(--pearl);
    border: none;
    width: 40px;
    height: 44px;
    cursor: pointer;
    font-size: 1.2rem;
    transition: background 0.15s;
  }

  .qty-btn:hover {
    background: var(--border);
  }

  .variant-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .variant-btn {
    padding: 0.4rem 1rem;
    border: 1px solid var(--border);
    background: var(--white);
    cursor: pointer;
    font-size: 0.8rem;
    border-radius: var(--radius-sm);
    transition: all 0.15s;
  }

  .variant-btn:hover,
  .variant-btn.selected {
    border-color: var(--obsidian);
    background: var(--obsidian);
    color: var(--white);
  }

  .variant-btn.out-of-stock {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .product-trust-badge {
    font-size: 0.75rem;
    color: var(--ash);
    padding: 0.35rem 0.75rem;
    background: var(--pearl);
    border-radius: 100px;
  }

  .accordion-item {
    border-bottom: 1px solid var(--border);
  }

  .accordion-header {
    padding: var(--space-md) 0;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .accordion-header::-webkit-details-marker {
    display: none;
  }

  .accordion-header::after {
    content: '＋';
    color: var(--gold);
    font-size: 1.2rem;
  }

  details[open] .accordion-header::after {
    content: '−';
  }

  .accordion-body {
    padding: 0 0 var(--space-md);
    color: var(--ash);
    font-size: 0.9rem;
    line-height: 1.8;
  }

  @media(max-width:768px) {
    .product-detail-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>

<%- include('partials/footer') %>

<script>
  const variants = <%- variantsJson %>;
  const selectedOptions = {};
  let selectedVariant = variants.length === 1 ? variants[0] : null;

  function switchImage(src, el) {
    document.getElementById('main-image').src = src;
    document.querySelectorAll('.product-image-thumb').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }

  // Thumbnail click delegation
  document.querySelectorAll('.product-image-thumb').forEach(thumb => {
    thumb.addEventListener('click', function() {
      switchImage(this.dataset.imgUrl, this);
    });
  });

  function changeQty(delta) {
    const inp = document.getElementById('qty-input');
    const max = selectedVariant ? selectedVariant.stock_quantity : 99;
    inp.value = Math.max(1, Math.min(max || 99, parseInt(inp.value) + delta));
    document.getElementById('form-qty').value = inp.value;
  }

  document.getElementById('qty-minus')?.addEventListener('click', () => changeQty(-1));
  document.getElementById('qty-plus')?.addEventListener('click', () => changeQty(1));

  document.getElementById('qty-input')?.addEventListener('input', function() {
    document.getElementById('form-qty').value = this.value;
  });

  // Variant selection
  document.querySelectorAll('.variant-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const type = this.dataset.type;
      const val = this.dataset.value;
      selectedOptions[type] = val;

      // Update selected label
      const label = document.querySelector(`[id="selected-${type.toLowerCase()}"]`);
      if (label) label.textContent = val;

      // Remove active from same type
      document.querySelectorAll(`.variant-btn[data-type="${type}"]`).forEach(b => b.classList.remove('selected'));
      this.classList.add('selected');

      // Find matching variant
      const match = variants.find(v => {
        if (!v.attributes) return false;
        return Object.entries(selectedOptions).every(([t, val]) =>
          v.attributes.some(a => a && a.attribute_type === t && a.attribute_value === val)
        );
      });

      const atcBtn = document.getElementById('atc-btn');
      const atcText = document.getElementById('atc-text');

      if (match) {
        selectedVariant = match;
        document.getElementById('selected-variant-id').value = match.id;
        const price = parseFloat(match.price_override || match.effective_price || 0);
        document.getElementById('variant-price').textContent = `R ${price.toFixed(2)}`;
        if (match.stock_quantity <= 0 && !match.allow_backorder) {
          atcBtn.disabled = true;
          atcText.textContent = 'Sold Out';
        } else {
          atcBtn.disabled = false;
          atcText.textContent = 'Add to Cart';
        }
      } else {
        // No variant matches the current combination of selected options
        selectedVariant = null;
        document.getElementById('selected-variant-id').value = '';
        atcBtn.disabled = true;
        atcText.textContent = 'Unavailable';
      }
    });
  });

  // Auto-select first variant options
  if (variants.length > 0 && variants[0].attributes) {
    variants[0].attributes.forEach(a => {
      if (a) {
        const btn = document.querySelector(`.variant-btn[data-type="${a.attribute_type}"][data-value="${a.attribute_value}"]`);
        btn?.click();
      }
    });
  }

  // AJAX add to cart
  document.getElementById('add-to-cart-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('atc-btn');
    const txt = document.getElementById('atc-text');
    btn.disabled = true;
    txt.textContent = 'Adding...';
    try {
      const fd = new FormData(this);
      const res = await fetch('/cart/add', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded'
        },
        body: new URLSearchParams(fd),
      });
      const data = await res.json();
      if (data.success) {
        txt.textContent = '✓ Added!';
        const badge = document.getElementById('cart-count');
        if (badge) {
          badge.textContent = data.cartCount;
          badge.classList.add('bump');
          setTimeout(() => badge.classList.remove('bump'), 400);
        }
        setTimeout(() => {
          btn.disabled = false;
          txt.textContent = 'Add to Cart';
        }, 2000);
      } else {
        txt.textContent = data.error || 'Error';
        setTimeout(() => {
          btn.disabled = false;
          txt.textContent = 'Add to Cart';
        }, 2000);
      }
    } catch (err) {
      txt.textContent = 'Error';
      setTimeout(() => {
        btn.disabled = false;
        txt.textContent = 'Add to Cart';
      }, 2000);
    }
  });

  // Wishlist
  document.querySelector('.wishlist-btn')?.addEventListener('click', async function() {
    const pid = this.dataset.productId;
    const res = await fetch('/wishlist/toggle', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        productId: pid
      })
    });
    const data = await res.json();
    if (data.added) {
      this.classList.add('btn-outline-gold');
      this.querySelector('svg').setAttribute('fill', 'currentColor');
    } else {
      this.classList.remove('btn-outline-gold');
      this.querySelector('svg').setAttribute('fill', 'none');
    }
  });
</script>
</body>

</html>