<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>
<main>
<div class="container" style="padding:var(--space-2xl) var(--space-lg) var(--space-3xl);">
  <div style="display:grid;grid-template-columns:240px 1fr;gap:var(--space-2xl);">
    <!-- Sidebar -->
    <%- include('./sidebar') %>

    <!-- Content -->
    <div>
      <h1 style="font-family:var(--font-serif);font-size:2rem;font-weight:300;margin-bottom:var(--space-sm);">
        Welcome back, <%= user.first_name %>
      </h1>
      <p class="text-muted" style="margin-bottom:var(--space-2xl);">Manage your orders, wishlist, and account settings.</p>

      <!-- Stats -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-lg);margin-bottom:var(--space-2xl);">
        <div class="card card-body" style="text-align:center;">
          <div style="font-family:var(--font-serif);font-size:2.5rem;color:var(--gold);"><%= recentOrders.length || 0 %></div>
          <div class="letter-wide text-muted" style="margin-top:0.5rem;">Orders</div>
        </div>
        <div class="card card-body" style="text-align:center;">
          <div style="font-family:var(--font-serif);font-size:2.5rem;color:var(--gold);"><%= wishlistCount || 0 %></div>
          <div class="letter-wide text-muted" style="margin-top:0.5rem;">Wishlist</div>
        </div>
        <div class="card card-body" style="text-align:center;">
          <div style="font-family:var(--font-serif);font-size:2.5rem;color:var(--gold);"><%= user.loyalty_points || 0 %></div>
          <div class="letter-wide text-muted" style="margin-top:0.5rem;">Points</div>
        </div>
      </div>

      <!-- Recent Orders -->
      <% if (recentOrders && recentOrders.length) { %>
      <h2 style="font-family:var(--font-serif);font-size:1.4rem;font-weight:400;margin-bottom:var(--space-lg);">Recent Orders</h2>
      <div class="table-wrap card">
        <table>
          <thead><tr><th>Order</th><th>Date</th><th>Status</th><th>Total</th><th></th></tr></thead>
          <tbody>
          <% recentOrders.forEach(o => { %>
          <tr>
            <td><strong>#<%= o.order_number %></strong></td>
            <td style="color:var(--silver);font-size:0.85rem;"><%= new Date(o.created_at).toLocaleDateString('en-ZA') %></td>
            <td><span class="status-pill status-<%= o.status %>"><%= o.status.replace(/_/g,' ') %></span></td>
            <td><strong><%= formatCurrency(o.total_amount) %></strong></td>
            <td><a href="/orders/<%= o.uuid %>" style="color:var(--gold);font-size:0.8rem;">View →</a></td>
          </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <div style="margin-top:var(--space-md);"><a href="/orders" class="btn btn-outline btn-sm">View All Orders</a></div>
      <% } else { %>
      <div class="empty-state">
        <div class="empty-state__icon">📦</div>
        <p class="empty-state__title">No orders yet</p>
        <p class="empty-state__text">Your order history will appear here.</p>
        <a href="/shop" class="btn btn-gold">Shop Now</a>
      </div>
      <% } %>
    </div>
  </div>
</div>
</main>
<%- include('../partials/footer') %>
</body></html>
