<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>
<main>
<div class="container" style="padding:var(--space-2xl) var(--space-lg) var(--space-3xl);max-width:860px;">
  <div style="margin-bottom:var(--space-xl);">
    <a href="/orders" style="color:var(--gold);font-size:0.85rem;">← My Orders</a>
  </div>
  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:var(--space-md);margin-bottom:var(--space-2xl);">
    <div>
      <h1 style="font-family:var(--font-serif);font-size:2rem;font-weight:300;">Order #<%= order.order_number %></h1>
      <p style="color:var(--silver);font-size:0.85rem;margin-top:0.25rem;">Placed <%= new Date(order.created_at).toLocaleDateString('en-ZA',{weekday:'long',day:'2-digit',month:'long',year:'numeric'}) %></p>
    </div>
    <span class="status-pill status-<%= order.status %>" style="font-size:0.8rem;padding:0.35rem 1rem;"><%= order.status.replace(/_/g,' ').toUpperCase() %></span>
  </div>

  <div style="display:grid;grid-template-columns:1fr 320px;gap:var(--space-2xl);align-items:start;">
    <!-- Left: Items + History -->
    <div>
      <!-- Items -->
      <div class="card" style="margin-bottom:var(--space-xl);">
        <div class="card-body">
          <h2 style="font-family:var(--font-serif);font-size:1.3rem;font-weight:400;margin-bottom:var(--space-lg);">Items Ordered</h2>
          <% items.forEach(item => { %>
          <div style="display:flex;gap:var(--space-md);padding:var(--space-md) 0;border-bottom:1px solid var(--border);">
            <% if (item.product_image_url) { %>
            <img src="<%= item.product_image_url %>" style="width:72px;height:72px;object-fit:cover;border-radius:var(--radius-sm);">
            <% } else { %>
            <div style="width:72px;height:72px;background:var(--pearl);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:1.5rem;">🏛</div>
            <% } %>
            <div style="flex:1;">
              <div style="font-weight:600;font-size:0.95rem;"><%= item.product_name %></div>
              <% if (item.variant_description) { %><div style="font-size:0.8rem;color:var(--silver);margin-top:0.2rem;"><%= item.variant_description %></div><% } %>
              <div style="font-size:0.8rem;color:var(--silver);margin-top:0.2rem;">SKU: <%= item.sku || 'N/A' %></div>
              <div style="margin-top:0.35rem;font-size:0.85rem;">Qty: <%= item.quantity %> × <%= formatCurrency(item.unit_price) %></div>
            </div>
            <div style="font-weight:700;font-size:1rem;white-space:nowrap;"><%= formatCurrency(item.line_total) %></div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Status History -->
      <% if (history && history.length) { %>
      <div class="card">
        <div class="card-body">
          <h2 style="font-family:var(--font-serif);font-size:1.3rem;font-weight:400;margin-bottom:var(--space-lg);">Order Timeline</h2>
          <div style="position:relative;padding-left:var(--space-xl);">
            <div style="position:absolute;left:0;top:0;bottom:0;width:1px;background:var(--border);margin-left:6px;"></div>
            <% history.forEach((h,i) => { %>
            <div style="position:relative;margin-bottom:var(--space-lg);">
              <div style="position:absolute;left:calc(-1*var(--space-xl));top:3px;width:12px;height:12px;border-radius:50%;background:<%= i===0?'var(--gold)':'var(--border)' %>;border:2px solid var(--white);box-shadow:0 0 0 2px <%= i===0?'var(--gold)':'var(--silver)' %>;"></div>
              <div style="font-size:0.8rem;font-weight:600;text-transform:capitalize;color:var(--obsidian);"><%= h.status.replace(/_/g,' ') %></div>
              <% if (h.note) { %><div style="font-size:0.8rem;color:var(--ash);margin-top:0.2rem;"><%= h.note %></div><% } %>
              <div style="font-size:0.72rem;color:var(--silver);margin-top:0.2rem;"><%= new Date(h.created_at).toLocaleString('en-ZA') %></div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Right: Summary -->
    <div>
      <div class="card" style="margin-bottom:var(--space-lg);">
        <div class="card-body">
          <h2 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;margin-bottom:var(--space-lg);">Order Summary</h2>
          <div style="display:flex;justify-content:space-between;margin-bottom:0.5rem;font-size:0.9rem;"><span style="color:var(--silver);">Subtotal</span><span><%= formatCurrency(order.subtotal) %></span></div>
          <div style="display:flex;justify-content:space-between;margin-bottom:0.5rem;font-size:0.9rem;"><span style="color:var(--silver);">Shipping</span><span><%= parseFloat(order.shipping_cost)===0?'FREE':formatCurrency(order.shipping_cost) %></span></div>
          <% if (order.discount_amount > 0) { %><div style="display:flex;justify-content:space-between;margin-bottom:0.5rem;font-size:0.9rem;color:#27ae60;"><span>Discount</span><span>−<%= formatCurrency(order.discount_amount) %></span></div><% } %>
          <div style="display:flex;justify-content:space-between;padding-top:var(--space-md);border-top:1px solid var(--border);font-weight:700;font-size:1rem;"><span>Total</span><span style="color:var(--gold);"><%= formatCurrency(order.total_amount) %></span></div>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <h2 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;margin-bottom:var(--space-md);">Delivery Address</h2>
          <address style="font-style:normal;font-size:0.9rem;color:var(--ash);line-height:1.8;">
            <strong style="color:var(--obsidian);"><%= order.shipping_first_name %> <%= order.shipping_last_name %></strong><br>
            <% if (order.shipping_company) { %><%= order.shipping_company %><br><% } %>
            <%= order.shipping_address_line_1 %><br>
            <% if (order.shipping_address_line_2) { %><%= order.shipping_address_line_2 %><br><% } %>
            <%= order.shipping_city %>, <%= order.shipping_province %> <%= order.shipping_postal_code %><br>
            <%= order.shipping_country %>
          </address>
        </div>
      </div>
    </div>
  </div>
</div>
</main>
<%- include('../partials/footer') %>
</body></html>
