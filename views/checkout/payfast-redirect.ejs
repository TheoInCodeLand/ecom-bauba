<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redirecting to payment...</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=Montserrat:wght@400;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Montserrat', sans-serif; background: #0a0a0a; color: white; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .wrap { text-align: center; max-width: 480px; }
    h1 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; margin-bottom: 0.5rem; color: #c9a96e; }
    p { color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-bottom: 2rem; }
    .spinner { width: 36px; height: 36px; border: 2px solid rgba(201,169,110,0.3); border-top-color: #c9a96e; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 2rem auto; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>Maison Luxe</h1>
    <p>Redirecting you to PayFast for secure payment…</p>
    <div class="spinner"></div>

    <form id="payfast-form" action="<%= payfastUrl %>" method="POST">
      <% Object.entries(payfastData).forEach(([key, value]) => { %>
        <input type="hidden" name="<%= key %>" value="<%= value %>">
      <% }) %>
    </form>
  </div>

  <script>
    // Auto-submit after brief delay so user sees the page
    setTimeout(() => document.getElementById('payfast-form').submit(), 1200);
  </script>
</body>
</html>
