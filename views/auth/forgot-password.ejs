<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>
<main>
<section style="min-height:70vh;display:flex;align-items:center;justify-content:center;padding:var(--space-2xl) var(--space-md);">
  <div style="width:100%;max-width:440px;text-align:center;">
    <a href="/" class="nav-logo" style="display:inline-block;margin-bottom:var(--space-2xl);">Maison<span style="color:var(--gold)">.</span>Luxe</a>
    <h1 style="font-family:var(--font-serif);font-size:1.8rem;font-weight:300;margin-bottom:var(--space-sm);">Forgot your password?</h1>
    <p style="color:var(--silver);margin-bottom:var(--space-2xl);">Enter your email and we'll send you a reset link if an account exists.</p>
    <div class="card"><div class="card-body" style="padding:var(--space-2xl);">
      <form method="POST" action="/auth/forgot-password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label class="form-label" for="email">Email Address</label>
          <input class="form-control" type="email" name="email" id="email" required placeholder="your@email.com">
        </div>
        <button type="submit" class="btn btn-primary btn-full">Send Reset Link</button>
      </form>
    </div></div>
    <p style="margin-top:var(--space-lg);color:var(--silver);font-size:0.875rem;">
      Remembered it? <a href="/auth/login" style="color:var(--gold)">Sign in</a>
    </p>
  </div>
</section>
</main>
<%- include('../partials/footer') %>
</body></html>
